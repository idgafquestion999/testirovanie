import pytest
from app.repository import add_user, get_user_by_name, get_all_users

@pytest.mark.integration
def test_add_and_get_user(db_connection):
    add_user(db_connection, "Alice")
    user = get_user_by_name(db_connection, "Alice")
    assert user is not None
    assert user[1] == "Alice"

@pytest.mark.integration
def test_get_all_users(db_connection):
    add_user(db_connection, "Alice")
    add_user(db_connection, "Bob")
    users = get_all_users(db_connection)
    assert len(users) == 2
    assert users[0][1] == "Alice"
    assert users[1][1] == "Bob"

@pytest.mark.integration
@pytest.mark.parametrize("name", ["Charlie", "David", "Eve"])
def test_add_multiple_users(db_connection, name):
    add_user(db_connection, name)
    user = get_user_by_name(db_connection, name)
    assert user[1] == name
